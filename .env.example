# ── Secrets do Supabase (configurar no dashboard → Edge Functions → Secrets) ──
# VAPID_PUBLIC_KEY=    (chave publica VAPID para web push)
# VAPID_PRIVATE_KEY=   (chave privada VAPID correspondente - PKCS8 base64url)
# VAPID_SUBJECT=mailto:admin@ipda.org.br
# INTERNAL_KEY=        (segredo para backend chamar notifications-api)
# CRON_SECRET=         (segredo para pg_cron chamar birthday notification)
